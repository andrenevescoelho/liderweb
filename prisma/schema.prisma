generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum Role {
  SUPERADMIN
  ADMIN
  LEADER
  MEMBER
}

enum VoiceType {
  SOPRANO
  ALTO
  TENOR
  LEAD
}

enum MemberFunctionLegacy {
  VOCAL
  TECLADO
  VIOLAO
  GUITARRA
  BAIXO
  BATERIA
  PERCUSSAO
  BACKING_VOCAL
  SOPRO
  MIDIA
  SOM
  LIDER
  OUTRO
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum RehearsalType {
  GENERAL
  VOCAL
  BAND
  TECHNICAL
  DEVOTIONAL
}

enum RehearsalStatus {
  DRAFT
  PUBLISHED
  COMPLETED
}

enum RehearsalAttendanceStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum RehearsalSongStatus {
  REHEARSAL_ONLY
  REHEARSED
  PROMOTED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  CANCELED
  PAST_DUE
  UNPAID
  INACTIVE
}

enum CouponType {
  PERCENTAGE_DISCOUNT
  FREE_PLAN
}

enum PlanTier {
  BASIC
  INTERMEDIATE
  ADVANCED
  ENTERPRISE
}

enum CouponRedemptionStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum SongSourceType {
  YOUTUBE
  UPLOAD
}

enum SongAnalysisStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum AuditEntityType {
  AUTH
  USER
  GROUP
  ANNOUNCEMENT
  REHEARSAL
  SCALE
  SONG
  COACH
  IMPORT
  SUBSCRIPTION
  RBAC
  MULTITRACK
  OTHER
}

enum MultitracksAlbumStatus {
  PENDING
  READY
  ERROR
}

enum MultitracksRentalStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum AnnouncementType {
  INFO
  FEATURE
  PROMOTION
  ALERT
  MAINTENANCE
}

enum AnnouncementStatus {
  DRAFT
  ACTIVE
  INACTIVE
  EXPIRED
}

enum AnnouncementTargetScope {
  ALL_PLATFORM
  SELECTED_GROUPS
}

enum AnnouncementTargetAudience {
  ADMINS_ONLY
  ALL_USERS
}

enum ImportType {
  MEMBERS
  SONGS
}

enum ImportMode {
  VALIDATE_ONLY
  CREATE_ONLY
  CREATE_OR_UPDATE
}

enum ImportJobStatus {
  VALIDATED
  COMPLETED
  FAILED
}

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  logo        String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
  songs       Song[]
  setlists    Setlist[]
  schedules   Schedule[]
  subscription Subscription?
  inviteTokens InviteToken[]
  rehearsals   Rehearsal[]
  messages     GroupMessage[]
  broadcasts   GroupBroadcast[]
  roleFunctions RoleFunction[]
  auditLogs    AuditLog[]
  importJobs   ImportJob[]
  announcementTargets AnnouncementGroup[]
  musicCoachProfiles  MusicCoachProfile[]
  practiceSubmissions PracticeSubmission[]
  progressHistories   ProgressHistory[]
  coachContentCaches  CoachContentCache[]
  multitracksRentals  MultitracksRental[]
  multitracksUsage    MultitracksUsage[]
}

model SubscriptionPlan {
  id            String   @id @default(cuid())
  name          String
  stripePriceId String   @unique
  price         Float
  userLimit     Int      // Limite de usuários (0 = ilimitado)
  features      String[] @default([])
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  subscriptions Subscription[]
}

model Subscription {
  id                   String             @id @default(cuid())
  groupId              String             @unique
  group                Group              @relation(fields: [groupId], references: [id], onDelete: Cascade)
  planId               String
  plan                 SubscriptionPlan   @relation(fields: [planId], references: [id])
  stripeCustomerId     String?
  stripeSubscriptionId String?            @unique
  status               SubscriptionStatus @default(INACTIVE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  trialEndsAt          DateTime?
  couponRedemptions    CouponRedemption[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model Coupon {
  id                   String             @id @default(cuid())
  code                 String             @unique
  name                 String
  description          String?
  type                 CouponType
  discountPercent      Int?
  freePlanTier         PlanTier?
  freePlanDurationDays Int?
  allowedPlanTiers     PlanTier[]         @default([])
  isActive             Boolean            @default(true)
  maxUses              Int?
  usedCount            Int                @default(0)
  validFrom            DateTime?
  validUntil           DateTime?
  createdByUserId      String
  createdByUser        User               @relation("CouponCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  redemptions          CouponRedemption[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([code])
}

model CouponRedemption {
  id               String                 @id @default(cuid())
  couponId         String
  coupon           Coupon                 @relation(fields: [couponId], references: [id], onDelete: Restrict)
  subscriptionId   String
  subscription     Subscription           @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  redeemedByUserId String
  redeemedByUser   User                   @relation("CouponRedeemer", fields: [redeemedByUserId], references: [id], onDelete: Restrict)
  redeemedAt       DateTime               @default(now())
  benefitStartAt   DateTime
  benefitEndAt     DateTime?
  status           CouponRedemptionStatus @default(ACTIVE)
  snapshotJson     Json?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@index([subscriptionId, status])
  @@index([couponId])
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String?
  role          Role      @default(MEMBER)
  groupId       String?
  group         Group?    @relation(fields: [groupId], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  profile       MemberProfile?
  scheduleRoles ScheduleRole[]
  rehearsalAttendances RehearsalAttendance[]
  rehearsalTasks RehearsalTask[]
  sentGroupMessages GroupMessage[] @relation("GroupMessageSender")
  sentGroupBroadcasts GroupBroadcast[] @relation("GroupBroadcastSender")
  memberFunctions MemberFunction[] @relation("UserMemberFunctions")
  scheduleMemberRoles ScaleMemberRole[] @relation("ScaleMemberRolesByMember")
  rehearsalMemberRoles RehearsalMemberRole[] @relation("RehearsalMemberRolesByMember")
  createdCoupons Coupon[] @relation("CouponCreator")
  redeemedCoupons CouponRedemption[] @relation("CouponRedeemer")
  accounts      Account[]
  sessions      Session[]
  auditLogs     AuditLog[]
  importJobs    ImportJob[]
  createdAnnouncements Announcement[] @relation("AnnouncementCreator")
  announcementReceipts AnnouncementReceipt[]
  musicCoachProfiles  MusicCoachProfile[]
  practiceSubmissions PracticeSubmission[]
  progressHistories   ProgressHistory[]
  coachContentCaches  CoachContentCache[]
}

model CoachContentCache {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId     String
  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  contentType String
  content     String   @db.Text
  generatedAt DateTime @default(now())

  @@unique([userId, groupId, contentType])
  @@index([userId, groupId, generatedAt])
}

model MusicCoachProfile {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  enabled   Boolean  @default(true)
  level     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, groupId])
  @@index([groupId, enabled])
}

model PracticeSubmission {
  id         String            @id @default(cuid())
  userId     String
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId    String
  group      Group             @relation(fields: [groupId], references: [id], onDelete: Cascade)
  audioUrl   String?
  type       String
  instrument String?
  notes      String?           @db.Text
  feedback   PracticeFeedback?
  createdAt  DateTime          @default(now())

  @@index([userId, createdAt])
  @@index([groupId, createdAt])
}

model PracticeFeedback {
  id           String             @id @default(cuid())
  submissionId String             @unique
  submission   PracticeSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  score        Int?
  feedback     String?            @db.Text
  suggestions  String?            @db.Text
  metricsJson  Json?
  createdAt    DateTime           @default(now())
}

model ProgressHistory {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId    String
  group      Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  metricType String
  value      Float
  createdAt  DateTime @default(now())

  @@index([userId, metricType, createdAt])
  @@index([groupId, createdAt])
}

model Announcement {
  id             String                     @id @default(cuid())
  title          String
  message        String                     @db.Text
  type           AnnouncementType           @default(INFO)
  status         AnnouncementStatus         @default(DRAFT)
  targetScope    AnnouncementTargetScope    @default(ALL_PLATFORM)
  targetAudience AnnouncementTargetAudience @default(ALL_USERS)
  startsAt       DateTime?
  expiresAt      DateTime?
  isActive       Boolean                    @default(true)
  ctaLabel       String?
  ctaUrl         String?
  priority       Int                        @default(0)
  metadata       Json?
  createdBy      String
  createdByUser  User                       @relation("AnnouncementCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  targetGroups   AnnouncementGroup[]
  receipts       AnnouncementReceipt[]

  @@index([status, isActive])
  @@index([startsAt, expiresAt])
  @@index([targetScope, targetAudience])
  @@index([priority, createdAt])
}

model AnnouncementGroup {
  id             String       @id @default(cuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  groupId        String
  group          Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([announcementId, groupId])
  @@index([groupId])
}

model AnnouncementReceipt {
  id             String       @id @default(cuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveredAt    DateTime?
  viewedAt       DateTime?
  dismissedAt    DateTime?
  createdAt      DateTime     @default(now())

  @@unique([announcementId, userId])
  @@index([userId, viewedAt])
}

model ImportJob {
  id          String          @id @default(cuid())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId     String?
  group       Group?          @relation(fields: [groupId], references: [id], onDelete: SetNull)
  importType  ImportType
  mode        ImportMode
  filename    String
  totalRows   Int             @default(0)
  successRows Int             @default(0)
  updatedRows Int             @default(0)
  ignoredRows Int             @default(0)
  errorRows   Int             @default(0)
  status      ImportJobStatus @default(VALIDATED)
  summary     String?
  detailsJson Json?

  @@index([userId, createdAt])
  @@index([groupId, createdAt])
  @@index([importType, createdAt])
  @@index([status, createdAt])
}

model AuditLog {
  id          String          @id @default(cuid())
  createdAt   DateTime        @default(now())
  userId      String?
  user        User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  groupId     String?
  group       Group?          @relation(fields: [groupId], references: [id], onDelete: SetNull)
  action      String
  entityType  AuditEntityType @default(OTHER)
  entityId    String?
  entityName  String?
  description String
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  oldValues   Json?
  newValues   Json?

  @@index([createdAt])
  @@index([userId])
  @@index([groupId])
  @@index([action])
  @@index([entityType])
}

model GroupMessage {
  id           String   @id @default(cuid())
  groupId      String
  group        Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  senderUserId String
  sender       User     @relation("GroupMessageSender", fields: [senderUserId], references: [id], onDelete: Cascade)
  content      String   @db.Text
  createdAt    DateTime @default(now())

  @@index([groupId, createdAt])
}

model GroupBroadcast {
  id           String   @id @default(cuid())
  groupId      String
  group        Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  senderUserId String
  sender       User     @relation("GroupBroadcastSender", fields: [senderUserId], references: [id], onDelete: Cascade)
  senderRole   Role
  content      String   @db.Text
  createdAt    DateTime @default(now())

  @@index([groupId, createdAt])
}

model MemberProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // DEPRECATED: manter durante migração para tabela relacional MemberFunction.
  memberFunction  String?
  leadershipRole  String?
  permissions     String[] @default([])
  instruments     String[] @default([])
  voiceType       VoiceType?
  vocalRange      String?
  comfortableKeys String[] @default([])
  availability    String[] @default([])
  phone           String?
  birthDate       DateTime?
  city            String?
  state           String?
  bio             String? @db.Text
  avatarUrl       String?
  profileVoiceType String?
  vocalRangeKey   String?
  skillLevel      SkillLevel?
  availabilityNotes String? @db.Text
  repertoirePrefs String? @db.Text
  instagram       String?
  youtube         String?
  // DEPRECATED: manter durante migração para tabela relacional MemberFunction.
  memberFunctions MemberFunctionLegacy[] @default([])
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model RoleFunction {
  id          String   @id @default(cuid())
  name        String
  description String?
  groupId     String?
  group       Group?   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  members     MemberFunction[] @relation("RoleFunctionMembers")
  scheduleAssignments ScaleMemberRole[] @relation("ScaleMemberRolesByFunction")
  rehearsalAssignments RehearsalMemberRole[] @relation("RehearsalMemberRolesByFunction")

  @@unique([groupId, name])
  @@index([groupId])
}

model MemberFunction {
  id             String       @id @default(cuid())
  memberId       String
  member         User         @relation("UserMemberFunctions", fields: [memberId], references: [id], onDelete: Cascade)
  roleFunctionId String
  roleFunction   RoleFunction @relation("RoleFunctionMembers", fields: [roleFunctionId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([memberId, roleFunctionId])
  @@index([roleFunctionId])
}

model Song {
  id               String             @id @default(cuid())
  title            String
  artist           String?
  bpm              Int?
  originalKey      String             @default("C")
  timeSignature    String             @default("4/4")
  tags             String[]           @default([])
  lyrics           String?            @db.Text
  chordPro         String?            @db.Text
  chordUrl         String?            @db.Text
  audioUrl         String?
  youtubeUrl       String?
  sourceType       SongSourceType?
  analysisStatus   SongAnalysisStatus @default(PENDING)
  analysisError    String?            @db.Text
  bpmDetected      Int?
  keyDetected      String?
  modeDetected     String?
  confidenceBpm    Float?
  confidenceKey    Float?
  bpmUserOverride  Int?
  keyUserOverride  String?
  groupId          String?
  group            Group?             @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  setlistItems     SetlistItem[]
  attachments      Attachment[]
  rehearsalSongs   RehearsalSong[]
  multitracks      MultitracksAlbum[]
  padBoards        PadBoard[]
}

model Attachment {
  id              String   @id @default(cuid())
  songId          String
  song            Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
  fileName        String
  fileType        String
  cloudStoragePath String
  isPublic        Boolean  @default(false)
  createdAt       DateTime @default(now())
}

model Setlist {
  id        String   @id @default(cuid())
  name      String
  date      DateTime
  groupId   String?
  group     Group?   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  items     SetlistItem[]
  schedules Schedule[]
}

model SetlistItem {
  id          String  @id @default(cuid())
  setlistId   String
  setlist     Setlist @relation(fields: [setlistId], references: [id], onDelete: Cascade)
  songId      String
  song        Song    @relation(fields: [songId], references: [id], onDelete: Cascade)
  order       Int
  selectedKey String
}

model Schedule {
  id        String   @id @default(cuid())
  date      DateTime
  setlistId String?
  setlist   Setlist? @relation(fields: [setlistId], references: [id], onDelete: SetNull)
  groupId   String?
  group     Group?   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  roles     ScheduleRole[]
  memberRoles ScaleMemberRole[] @relation("ScaleMemberRolesBySchedule")
}

model ScheduleRole {
  id         String       @id @default(cuid())
  scheduleId String
  schedule   Schedule     @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  // DEPRECATED: manter temporariamente enquanto dados migram para ScaleMemberRole.
  role       String
  memberId   String?
  member     User?        @relation(fields: [memberId], references: [id], onDelete: SetNull)
  status     InviteStatus @default(PENDING)
}

model ScaleMemberRole {
  id             String       @id @default(cuid())
  scaleId        String
  scale          Schedule     @relation("ScaleMemberRolesBySchedule", fields: [scaleId], references: [id], onDelete: Cascade)
  memberId       String
  member         User         @relation("ScaleMemberRolesByMember", fields: [memberId], references: [id], onDelete: Cascade)
  roleFunctionId String
  roleFunction   RoleFunction @relation("ScaleMemberRolesByFunction", fields: [roleFunctionId], references: [id], onDelete: Restrict)
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([scaleId, memberId, roleFunctionId])
  @@index([scaleId, roleFunctionId])
  @@index([memberId, roleFunctionId])
}

// Token de convite para membros
model InviteToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  invitedBy String   // ID do usuário que convidou
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Rehearsal {
  id          String   @id @default(cuid())
  groupId     String?
  group       Group?   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  dateTime    DateTime
  location    String?
  notes       String?
  type        RehearsalType   @default(GENERAL)
  status      RehearsalStatus @default(DRAFT)
  estimatedMinutes Int?
  reminder24hEnabled Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  songs       RehearsalSong[]
  attendance  RehearsalAttendance[]
  checklist   RehearsalChecklistItem[]
  memberRoles RehearsalMemberRole[] @relation("RehearsalMemberRolesByRehearsal")

  @@index([groupId, dateTime])
}

model RehearsalMemberRole {
  id             String       @id @default(cuid())
  rehearsalId    String
  rehearsal      Rehearsal    @relation("RehearsalMemberRolesByRehearsal", fields: [rehearsalId], references: [id], onDelete: Cascade)
  memberId       String
  member         User         @relation("RehearsalMemberRolesByMember", fields: [memberId], references: [id], onDelete: Cascade)
  roleFunctionId String
  roleFunction   RoleFunction @relation("RehearsalMemberRolesByFunction", fields: [roleFunctionId], references: [id], onDelete: Restrict)
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([rehearsalId, memberId, roleFunctionId])
  @@index([rehearsalId, roleFunctionId])
  @@index([memberId, roleFunctionId])
}

model RehearsalSong {
  id          String   @id @default(cuid())
  rehearsalId String
  rehearsal   Rehearsal @relation(fields: [rehearsalId], references: [id], onDelete: Cascade)
  songId      String?
  song        Song?    @relation(fields: [songId], references: [id], onDelete: SetNull)
  title       String
  artist      String?
  order       Int
  key         String?
  bpm         Int?
  partNotes   String?
  notes       String?
  audioUrl    String?
  youtubeUrl  String?
  tags        String[] @default([])
  status      RehearsalSongStatus @default(REHEARSAL_ONLY)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tasks       RehearsalTask[]

  @@index([rehearsalId, order])
}

model RehearsalAttendance {
  id          String   @id @default(cuid())
  rehearsalId String
  rehearsal   Rehearsal @relation(fields: [rehearsalId], references: [id], onDelete: Cascade)
  memberId    String
  member      User     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  status      RehearsalAttendanceStatus @default(PENDING)
  justification String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@unique([rehearsalId, memberId])
}

model RehearsalChecklistItem {
  id          String   @id @default(cuid())
  rehearsalId String
  rehearsal   Rehearsal @relation(fields: [rehearsalId], references: [id], onDelete: Cascade)
  label       String
  done        Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RehearsalTask {
  id              String   @id @default(cuid())
  rehearsalSongId String
  rehearsalSong   RehearsalSong @relation(fields: [rehearsalSongId], references: [id], onDelete: Cascade)
  memberId        String
  member          User     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  notes           String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([rehearsalSongId, memberId])
}


model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@unique([userId, provider])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Módulo Multitracks ───────────────────────────────────────────────────────

model MultitracksAlbum {
  id          String                 @id @default(cuid())
  title       String
  artist      String
  genre       String?
  bpm         Int?
  musicalKey  String?
  coverUrl    String?
  description String?                @db.Text
  status      MultitracksAlbumStatus @default(PENDING)
  markers     Json                   @default("[]")
  stems       Json
  isActive    Boolean                @default(true)
  songId      String?
  song        Song?                  @relation(fields: [songId], references: [id], onDelete: SetNull)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  rentals     MultitracksRental[]

  @@index([status, isActive])
  @@index([title, artist])
  @@index([songId])
}

model MultitracksRental {
  id        String                  @id @default(cuid())
  groupId   String
  group     Group                   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  albumId   String
  album     MultitracksAlbum        @relation(fields: [albumId], references: [id], onDelete: Restrict)
  rentedBy  String                  // userId de quem alugou
  r2Folder  String                  // pasta no R2: multitracks/{groupId}/{albumId}
  status    MultitracksRentalStatus @default(ACTIVE)
  rentedAt  DateTime                @default(now())
  expiresAt DateTime
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  @@unique([groupId, albumId])
  @@index([groupId, status])
  @@index([albumId])
  @@index([expiresAt])
}

model MultitracksUsage {
  id        String   @id @default(cuid())
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  month     Int      // 1-12
  year      Int
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([groupId, month, year])
  @@index([groupId, year, month])
}

enum PadType {
  HOLD
  LOOP
  ONE_SHOT
}

model PadBoard {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  bpm         Int?
  musicalKey  String?
  color       String   @default("#8B5CF6")
  isActive    Boolean  @default(true)
  cols        Int      @default(4)
  rows        Int      @default(4)
  createdBy   String
  songId      String?
  song        Song?    @relation(fields: [songId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  pads        Pad[]

  @@index([isActive])
  @@index([songId])
}

model Pad {
  id          String   @id @default(cuid())
  boardId     String
  board       PadBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  name        String
  position    Int
  type        PadType  @default(ONE_SHOT)
  audioUrl    String?
  r2Key       String?
  color       String   @default("#6366F1")
  volume      Float    @default(1.0)
  midiNote    Int?
  keyboardKey String?
  loopSync    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([boardId, position])
  @@index([boardId, isActive])
}
